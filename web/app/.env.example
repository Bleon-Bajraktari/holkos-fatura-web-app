# ===========================================
# Holkos Fatura - Frontend Environment
# ===========================================
# Kopjo këtë skedar në .env dhe plotëso vlerat

# URL e API Backend - I NJËJTË për localhost dhe deploy
# Përdor /api gjithmonë - proxy/rewrites drejtojnë te backend-i i duhur
VITE_API_BASE=/api

# Localhost: Vite proxy (/api → localhost:8000) - shiko vite.config.ts
# Deploy (Vercel): vercel.json rewrites (/api → Render backend)

# Për SMTP nga Cilësimet (Vercel function) - vendos në Vercel Environment:
# BACKEND_URL=https://holkos-fatura-api.onrender.com

# Raporti mujor automatik (Vercel Cron → /api/monthly-invoices-report):
# Vendos në Vercel Environment një sekret të fortë (p.sh. openssl rand -hex 32).
# Vercel Cron e dërgon automatikisht si "Authorization: Bearer <CRON_SECRET>".
# Cron-i jashtëm (cron-job.org/GitHub Actions) duhet ta dërgojë vetë:
#   GET https://<domeni>/api/monthly-invoices-report  me header Authorization: Bearer <CRON_SECRET>
#   ose  .../api/monthly-invoices-report?key=<CRON_SECRET>
# CRON_SECRET=ndrysho-me-nje-sekret-te-forte
