{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "crons": [
    {
      "path": "/api/monthly-invoices-report",
      "schedule": "0 6 1 * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path((?!send-email-smtp)(?!send-bulk-email-smtp)(?!monthly-invoices-report).*)",
      "destination": "https://holkos-fatura-api.onrender.com/:path"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://holkos-fatura-api.onrender.com/uploads/:path*"
    },
    {
      "source": "/logo.png",
      "destination": "https://holkos-fatura-api.onrender.com/logo.png"
    },
    {
      "source": "/logo-dark.png",
      "destination": "https://holkos-fatura-api.onrender.com/logo-dark.png"
    },
    {
      "source": "/((?!api|uploads|assets|_next|favicon|icon|apple-touch|manifest\\.webmanifest).*)",
      "destination": "/index.html"
    }
  ]
}
